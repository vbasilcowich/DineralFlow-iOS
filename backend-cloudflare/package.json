{
  "name": "dineralflow-cloudflare-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create dineralflow",
    "db:migrate:local": "wrangler d1 migrations apply dineralflow --local",
    "db:migrate:remote": "wrangler d1 migrations apply dineralflow --remote"
  },
  "devDependencies": {
    "wrangler": "^4.87.0"
  }
}

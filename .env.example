# Local backend
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Billing mode
# Use `mock` while phase 1 is local-only and no real StoreKit or RevenueCat credentials exist.
# Switch to `revenuecat` only when you have a native build plus the values below.
# During the current Test Store phase, point `EXPO_PUBLIC_REVENUECAT_API_KEY_IOS`
# to the public Test Store key. Replace it later with the App Store iOS public SDK key.
EXPO_PUBLIC_BILLING_PROVIDER=mock

# RevenueCat public configuration for a native iOS development build
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default

# Backend API
# Local backend:
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Zero-cost Cloudflare Worker backend after deploy:
# EXPO_PUBLIC_API_BASE_URL=https://dineralflow-api.<your-subdomain>.workers.dev

# Auth mode
# Use `mock` while validating UI without backend auth.
# Use `backend` after the Cloudflare Worker is deployed and reachable.
EXPO_PUBLIC_AUTH_PROVIDER=mock

# Billing mode
# Use `mock` while phase 1 is local-only and no real StoreKit or RevenueCat credentials exist.
# Switch to `revenuecat` only when you have a native build plus the values below.
# During the current Test Store phase, point `EXPO_PUBLIC_REVENUECAT_API_KEY_IOS`
# to the public Test Store key. Replace it later with the App Store iOS public SDK key.
EXPO_PUBLIC_BILLING_PROVIDER=mock

# RevenueCat public configuration for a native iOS development build
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default

# Social sign-in
# Google requires client IDs from Google Cloud OAuth credentials.
# Apple uses the native iOS capability and a backend audience allowlist.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=

# Cloudflare backend secrets, configured with `wrangler secret put`.
# These are not EXPO_PUBLIC values and must not be shipped in the iOS app.
JWT_SECRET=
RESEND_API_KEY=
REVENUECAT_WEBHOOK_SECRET=
